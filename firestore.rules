service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: opportunities
    // Fields:
    //   - title: string (required)
    //   - organization: string
    //   - description: string
    //   - category: string (required, enum)
    //   - location: string
    //   - deadline: string (ISO date)
    //   - applyLink: string
    //   - tags: list
    //   - rawTelegramText: string
    //   - isApproved: bool (required)
    //   - isFeatured: bool
    //   - viewCount: int
    //   - createdAt: string (ISO date, required)
    //   - field: string
    //   - isRemote: bool
    //   - seoArticle: string
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (required, enum: admin, user)
    //
    // Collection: users/{userId}/bookmarks
    // Fields:
    //   - userId: string (required)
    //   - opportunityId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "ytsamuael@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidOpportunity(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.category in ["Internships", "Events", "Competitions", "Scholarships", "Jobs", "Fellowships", "Conferences", "Grants", "General"] &&
             data.isApproved is bool &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /opportunities/{opportunityId} {
      // Public can read approved opportunities
      // Admins can read everything
      allow read: if isAdmin() || (resource.data.isApproved == true);
      
      // Only admins can create/update/delete opportunities
      // Exception: We might want the server (which is admin) to create them.
      // But rules apply to client SDK.
      allow create, update, delete: if isAdmin();
      
      // Allow incrementing viewCount for anyone? 
      // Better to restrict it to prevent spam, but for a simple app it's often allowed.
      // However, we'll keep it admin-only for now and handle views via a server call or just let it be.
      // Actually, let's allow anyone to update ONLY the viewCount if it's an increment.
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
        request.resource.data.viewCount == resource.data.viewCount + 1
      ) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile as 'user'
      // Admins can create any profile
      allow create: if (isOwner(userId) && request.resource.data.role == 'user' && isValidUser(request.resource.data)) || isAdmin();
      
      // Only admins can change roles
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data)) || isAdmin();
      
      allow delete: if isAdmin();

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
