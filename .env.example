# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous API key.
SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase service role key (found in Settings > API).
# This is required to automatically create the admin user.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ADMIN_EMAIL: The email address for the admin account.
ADMIN_EMAIL="admin@opphub.com"

# ADMIN_PASSWORD: Password for the admin dashboard. 
# On Vercel, add this to your Project Settings > Environment Variables.
ADMIN_PASSWORD="admin123"

# JWT_SECRET: Secret for signing JWT tokens.
JWT_SECRET="change-this-to-a-secure-random-string"
